<Page
    x:Class="Scriptum.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Scriptum.ViewModels"
    xmlns:models="using:Scriptum.Models">

    <Page.DataContext>
        <vm:MainViewModel />
    </Page.DataContext>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel - Notebook List -->
        <StackPanel Grid.Column="0" Padding="16" Spacing="8">
            <TextBlock Text="Notebooks" FontSize="20" FontWeight="Bold"/>
            
            <Button Content="+ New Notebook" 
                    Click="NewNotebookButton_Click"
                    HorizontalAlignment="Stretch"/>
            
            <ListView ItemsSource="{x:Bind ViewModel.Notebooks, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedNotebook, Mode=TwoWay}"
                      Height="400">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Notebook">
                        <StackPanel Padding="8">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind Description}" 
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Content="Open Note Editor" 
                    Click="OpenNoteEditorButton_Click"
                    HorizontalAlignment="Stretch"
                    IsEnabled="{x:Bind ViewModel.SelectedNotebook != null, Mode=OneWay}"/>
        </StackPanel>

        <!-- Right Panel - Main Content -->
        <StackPanel Grid.Column="1" Padding="16" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
            <TextBlock Text="{x:Bind ViewModel.ApplicationTitle, Mode=OneWay}" 
                       FontSize="48" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}" 
                       FontSize="18" 
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Center"/>
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>
        </StackPanel>
    </Grid>
</Page>
