<Page
    x:Class="Scriptum.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Scriptum.Views">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="24,18"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="4">
                <TextBlock Text="{x:Bind ViewModel.ApplicationTitle, Mode=OneWay}"
                           FontSize="34"
                           FontWeight="Bold" />
                <TextBlock Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}"
                           FontSize="16"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>
        </Border>

        <views:PageCanvasView Grid.Row="1" />
    </Grid>
</Page>
