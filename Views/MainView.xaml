<Page
    x:Class="Scriptum.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Scriptum.Views"
    xmlns:viewModels="using:Scriptum.ViewModels"
    Loaded="Page_Loaded">

    <Grid Background="#151515">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#20201E"
                BorderBrush="#35332F"
                BorderThickness="0,0,1,0"
                Padding="22">
            <Grid RowSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock Text="{x:Bind ViewModel.ApplicationTitle, Mode=OneWay}"
                               Foreground="#F7F1E6"
                               FontSize="30"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Private notebook archive"
                               Foreground="#AFA89C"
                               FontSize="13" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="10">
                    <TextBlock Text="Library"
                               Foreground="#81796C"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <RadioButton Content="All Pages"
                                 IsChecked="True"
                                 Foreground="#F7F1E6" />
                    <RadioButton Content="Recent"
                                 Foreground="#D6CFC4" />
                    <RadioButton Content="Favorites"
                                 Foreground="#D6CFC4" />
                </StackPanel>

                <Grid Grid.Row="2" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="10">
                        <TextBlock Text="Imported Pages"
                                   Foreground="#81796C"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <ListView ItemsSource="{x:Bind ViewModel.ImportedPages, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedPage, Mode=TwoWay}"
                                  SelectionChanged="ImportedPages_SelectionChanged"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  MaxHeight="360">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ImportedPageListItemViewModel">
                                    <Grid Padding="4">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{x:Bind Title}"
                                                       Foreground="#F7F1E6"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind Metadata}"
                                                       Foreground="#AFA89C"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock Text="Import notebook photos, then select a page here to reopen its preserved image and digital text."
                                   TextWrapping="Wrap"
                                   Foreground="#81796C"
                                   FontSize="12" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="10">
                        <TextBlock Text="Notebooks / Projects"
                                   Foreground="#81796C"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Scriptum"
                                   Foreground="#F7F1E6"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Auralis"
                                   Foreground="#D6CFC4" />
                        <TextBlock Text="Metallic"
                                   Foreground="#D6CFC4" />
                        <TextBlock Text="Dev Notes"
                                   Foreground="#D6CFC4" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="3" Spacing="12">
                    <Border Background="#2A2926"
                            BorderBrush="#3A3833"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,12,0,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Next"
                                       Foreground="#F7F1E6"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Import pages, transcribe handwriting, then copy usable text into your development workflow."
                                       TextWrapping="Wrap"
                                       Foreground="#AFA89C"
                                       FontSize="12" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#AFA89C" />
                </StackPanel>
            </Grid>
        </Border>

        <views:NotebookPageView x:Name="NotebookPageSurface"
                                Grid.Column="1" />
    </Grid>
</Page>
